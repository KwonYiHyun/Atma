@page "/admin/cache/manage"

@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using AdminTool.API

@inject GameServerClient _gameClient
@inject IJSRuntime JS

<h3>⚡ 캐시 데이터 초기화</h3>
<p class="text-muted">
    Redis의 마스터 데이터를 삭제하고, 게임 서버의 로컬 캐시를 갱신합니다.
</p>

<div class="row g-4 mt-2">
    <div class="col-12">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white fw-bold">
                🚨 전체 캐시 초기화 (EMERGENCY)
            </div>
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <strong>모든 마스터 데이터(Master:*)를 삭제합니다.</strong>
                    <div class="small text-muted">서버 점검 직후나 데이터가 꼬였을 때만 사용하세요.</div>
                </div>
                <button class="btn btn-danger btn-lg" @onclick='() => RequestClearAsync("ALL")'>
                    전체 삭제 실행
                </button>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card">
            <div class="card-header bg-primary text-white">
                📋 개별 테이블 관리
            </div>
            <div class="card-body p-0">
                <table class="table table-striped table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 30%">테이블 이름</th>
                            <th style="width: 40%">Redis Key 패턴</th>
                            <th style="width: 30%" class="text-end">관리</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var target in cacheTargets)
                        {
                            <tr>
                                <td class="fw-bold">@target.Key</td>
                                <td class="small text-muted font-monospace">@target.Value</td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => RequestClearAsync(target.Key)">
                                        <i class="oi oi-reload"></i> 초기화
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private Dictionary<string, string> cacheTargets = new()
    {
        { "Item", "Master:Item:*" },
        { "Reward", "Master:Reward:*" },
        { "Banner", "Master:Banner:*" },
        { "Character", "Master:Character:*" },
        { "CharacterGrade", "Master:CharacterGrade:*" },
        { "CharacterLevel", "Master:CharacterLevel:*" },
        { "Loginbonus", "Master:Loginbonus:*" },
        { "LoginbonusDay", "Master:LoginbonusDay:*" },
        { "Gacha", "Master:Gacha:*" },
        { "GachaExec10", "Master:GachaExec10:*" },
        { "GachaLot", "Master:GachaLot:*" },
        { "GachaLotGroup", "Master:GachaLotGroup:*" },
        { "Product", "Master:Product:*" },
        { "ProductSet", "Master:ProductSet:*" },
        { "ProductSetPiece", "Master:ProductSetPiece:*" },
        { "ProductSetPrism", "Master:ProductSetPrism:*" },
        { "ProductSetToken", "Master:ProductSetToken:*" },
        { "Achievement", "Master:Achievement:*" },
        { "AchievementCategory", "Master:AchievementCategory:*" },
        { "Notice", "Master:Notice:*" },
        { "Mail", "Master:Mail:*" }
    };

    private async Task RequestClearAsync(string targetType)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"[{targetType}] 관련 모든 캐시를 삭제하시겠습니까?");
        if (confirmed)
        {
            var result = await _gameClient.clearCacheAsync(targetType);
            if (result.Item1)
            {
                await JS.InvokeVoidAsync("alert", "초기화 명령이 전송되었습니다.");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"초기화 실패: {result.Item2}");
            }
        }
    }
}