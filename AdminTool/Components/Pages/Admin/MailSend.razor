@page "/admin/mail/send"

@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using AdminTool.API
@using SharedData.Dto.Admin

@inject GameServerClient _gameClient
@inject IJSRuntime JS

<div class="container-fluid" style="max-width: 800px;">
    <h3 class="mb-4">📧 보상 우편 발송</h3>

    <div class="card mb-3">
        <div class="card-header bg-dark text-white fw-bold">1. 발송 대상 선택</div>
        <div class="card-body">
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="targetType" id="targetSingle" 
                       checked="@(!isTargetAll)" @onchange="() => isTargetAll = false">
                <label class="form-check-label" for="targetSingle">특정 유저 1명</label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="targetType" id="targetAll" 
                       checked="@isTargetAll" @onchange="() => isTargetAll = true">
                <label class="form-check-label fw-bold text-danger" for="targetAll">전체 유저 (All Users)</label>
            </div>

            <div class="mt-3">
                @if (!isTargetAll)
                {
                    <label class="form-label">받는 사람 (Person ID)</label>
                    <input type="number" class="form-control" @bind="targetPersonId" placeholder="유저 ID 입력" />
                }
                else
                {
                    <div class="alert alert-warning mb-0">
                        ⚠️ <strong>주의:</strong> 모든 유저에게 우편을 발송합니다. 데이터 양에 따라 시간이 소요될 수 있습니다.
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header bg-secondary text-white fw-bold">2. 우편 내용 (템플릿)</div>
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label">템플릿 선택 (master_mail)</label>
                <select class="form-select" @onchange="OnTemplateChanged">
                    <option value="0">== 템플릿을 선택하세요 ==</option>
                    @if (templates != null)
                    {
                        @foreach (var tmpl in templates)
                        {
                            <option value="@tmpl.mail_id">[@tmpl.mail_id] @tmpl.mail_subject</option>
                        }
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">제목 (Title)</label>
                <input type="text" class="form-control" @bind="mailTitle" />
            </div>
            <div class="mb-3">
                <label class="form-label">내용 (Description)</label>
                <textarea class="form-control" rows="4" @bind="mailBody"></textarea>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header bg-success text-white fw-bold">3. 동봉 보상 (Reward)</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Reward ID (master_reward)</label>
                    <input type="number" class="form-control" @bind="rewardId" placeholder="0이면 보상 없음" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">수량 (Amount)</label>
                    <input type="number" class="form-control" @bind="rewardAmount" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">만료일 (Expire Date)</label>
                    <input type="datetime-local" class="form-control" @bind="expireDate" />
                </div>
            </div>
        </div>
    </div>

    <div class="d-grid gap-2 mb-5">
        <button class="btn btn-primary btn-lg" @onclick="SendMailProcess" disabled="@isProcessing">
            @if (isProcessing)
            {
                <span class="spinner-border spinner-border-sm"></span> <span> 발송 중...</span>
            }
            else
            {
                <span>🚀 우편 발송 시작</span>
            }
        </button>
    </div>
</div>

@code {
    private List<MasterMailDto> templates = new();
    
    private bool isTargetAll = false;
    private int targetPersonId;
    
    private string mailTitle = "";
    private string mailBody = "";
    
    private int rewardId = 0;
    private int rewardAmount = 1;
    private DateTime expireDate = DateTime.Now.AddDays(7);

    private bool isProcessing = false;

    protected override async Task OnInitializedAsync()
    {
        templates = await _gameClient.getMails();
        
        if (templates != null)
        {
            templates = templates.OrderByDescending(m => m.mail_id).ToList();
        }
    }

    private void OnTemplateChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int selectedId) && selectedId > 0)
        {
            var selected = templates.FirstOrDefault(t => t.mail_id == selectedId);
            if (selected != null)
            {
                mailTitle = selected.mail_subject;
                mailBody = selected.mail_body;
            }
        }
        else
        {
            mailTitle = "";
            mailBody = "";
        }
    }

    private async Task SendMailProcess()
    {
        if (string.IsNullOrWhiteSpace(mailTitle))
        {
            await JS.InvokeVoidAsync("alert", "제목을 입력해주세요.");
            return;
        }
        if (!isTargetAll && targetPersonId <= 0)
        {
            await JS.InvokeVoidAsync("alert", "받는 유저의 ID를 입력해주세요.");
            return;
        }

        string confirmMsg = isTargetAll 
            ? "⚠️ [전체 유저]에게 우편을 발송하시겠습니까?\n이 작업은 취소할 수 없습니다." 
            : $"ID: {targetPersonId} 유저에게 우편을 발송하시겠습니까?";
            
        if (!await JS.InvokeAsync<bool>("confirm", confirmMsg)) return;

        isProcessing = true;
        StateHasChanged();

        try
        {
            var mailData = new PersonMailDto
            {
                person_id = isTargetAll ? 0 : targetPersonId, 
                title = mailTitle,
                description = mailBody,
                reward_id_1 = rewardId,
                reward_id_1_amount = rewardAmount,
                expire_date = expireDate
            };

            var result = await _gameClient.sendRewardMailAsync(mailData);
            
            if (result.Item1)
            {
                await JS.InvokeVoidAsync("alert", "발송 완료");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"발송 실패: {result.Item2}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"발송 중 오류 발생: {ex.Message}");
        }
        finally
        {
            isProcessing = false;
        }
    }
}