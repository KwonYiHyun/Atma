@page "/master/gachas"

@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using AdminTool.API
@using SharedData.Dto.Admin
@using SharedData.Models
@using SharedData.Type

@inject GameServerClient _gameClient
@inject IJSRuntime JS

<style>
    .table-scroll-container {
        height: calc(100vh - 250px);
        overflow-y: auto;
        border: 1px solid #dee2e6;
    }

        .table-scroll-container thead th {
            position: sticky;
            top: 0;
            z-index: 1;
        }

    .fab-btn {
        position: fixed;
        bottom: 30px;
        right: 30px;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        font-size: 30px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.3);
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding-bottom: 5px;
    }

    .img-preview {
        max-width: 50px;
        max-height: 50px;
        object-fit: cover;
        border: 1px solid #ccc;
    }
</style>

<h3>가챠(소환) 마스터 관리</h3>

<div class="row mb-3">
    <div class="col-md-6">
        <div class="input-group">
            <input type="text" class="form-control" placeholder="ID 또는 가챠 이름 검색"
                   @bind="searchText" @bind:event="oninput" @onkeyup="HandleKeyUp" />
            <button class="btn btn-primary" @onclick="SearchGachas">검색</button>
            <button class="btn btn-secondary" @onclick="ResetSearch">초기화</button>
        </div>
    </div>
</div>

@if (gachas == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="table-scroll-container bg-white">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark sticky-top">
                <tr>
                    <th style="width: 60px;">ID</th>
                    <th style="width: 60px;">순서</th>
                    <th>가챠 이름</th>
                    <th>타입</th>
                    <th>소모값</th>
                    <th>Lot ID</th>
                    <th>이미지</th>
                    <th>기간</th>
                    <th style="width: 100px;">관리</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var gacha in gachas)
                {
                    <tr>
                        <td>@gacha.gacha_id</td>
                        <td>@gacha.show_order</td>
                        <td>@gacha.gacha_name</td>
                        <td>
                            @switch ((GachaType)gacha.gacha_type)
                            {
                                case GachaType.START:
                                    <span class="badge bg-success">Start</span>
                                    break;
                                case GachaType.BASIC:

                                    <span class="badge bg-primary">Basic</span>
                                    break;
                                case GachaType.TICKET:

                                    <span class="badge bg-warning text-dark">Ticket</span>
                                    break;
                                default:

                                    <span class="badge bg-secondary">Unknown</span>
                                    break;
                            }
                        </td>
                        <td>
                            @gacha.gacha_consume_value
                            @if (gacha.gacha_type == (int)GachaType.TICKET)
                            {
                                <small class="text-muted">(ItemID: @gacha.gacha_coupon_item_id)</small>
                            }
                        </td>
                        <td>
                            @* 나중에 이 ID를 클릭하면 확률표 관리 페이지로 이동하게 하면 좋습니다 *@
                            <a href="#" class="text-decoration-none fw-bold">@gacha.gacha_lot_group_id</a>
                        </td>
                        <td>@gacha.gacha_image</td>
                        <td>
                            <small>
                                @gacha.start_date.ToString("yy-MM-dd HH:mm") <br />
                                @(gacha.end_date.HasValue? gacha.end_date.Value.ToString("yy-MM-dd HH:mm") : "무기한")
                            </small>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-info text-white" @onclick="() => OpenEditModal(gacha)">
                                상세
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<button class="btn btn-primary fab-btn" @onclick="OpenAddModal" title="신규 추가"> + </button>

@if (showModal && editingGacha != null)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @(isNew ? "신규 가챠 등록" : $"가챠 수정 ({editingGacha.gacha_id})")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">

                    <h6 class="border-bottom pb-2 mb-3 text-primary">기본 정보</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-2">
                            <label class="form-label fw-bold">ID (PK)</label>
                            <input type="number" class="form-control" @bind="editingGacha.gacha_id" disabled="@(!isNew)" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">표시 순서</label>
                            <input type="number" class="form-control" @bind="editingGacha.show_order" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">가챠 이름</label>
                            <input type="text" class="form-control" @bind="editingGacha.gacha_name" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">가챠 타입</label>
                            <select class="form-select" @bind="editingGacha.gacha_type">
                                @foreach (GachaType type in Enum.GetValues(typeof(GachaType)))
                                {
                                    <option value="@((int)type)">@type.ToString()</option>
                                }
                            </select>
                        </div>
                    </div>

                    <h6 class="border-bottom pb-2 mb-3 text-primary">비용 및 로직 설정</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-3">
                            <label class="form-label">소모값 (가격)</label>
                            <input type="number" class="form-control" @bind="editingGacha.gacha_consume_value" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">소모 아이템 ID (티켓 등)</label>
                            <input type="number" class="form-control" @bind="editingGacha.gacha_coupon_item_id" />
                            <div class="form-text">0이면 유료 재화(보석) 사용</div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold text-danger">확률 그룹 ID (Lot Group)</label>
                            <input type="number" class="form-control" @bind="editingGacha.gacha_lot_group_id" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">10연차 확률 그룹 ID</label>
                            <input type="number" class="form-control" @bind="editingGacha.gacha_exec_10_id" />
                            <div class="form-text">NULL 가능</div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">마일리지 포인트 획득량</label>
                            <input type="number" class="form-control" @bind="editingGacha.gacha_point" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">보너스 보상 그룹 ID</label>
                            <input type="number" class="form-control" @bind="editingGacha.gacha_bonus_reward_group_lot_id" />
                        </div>
                    </div>

                    <h6 class="border-bottom pb-2 mb-3 text-primary">이미지 및 상세 텍스트</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label">메인 배너 이미지</label>
                            <input type="text" class="form-control" @bind="editingGacha.gacha_image" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">상세 팝업 이미지</label>
                            <input type="text" class="form-control" @bind="editingGacha.gacha_detail_image" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">상세 설명 주소</label>
                            <textarea class="form-control" rows="3" @bind="editingGacha.gacha_detail_html"></textarea>
                        </div>
                    </div>

                    <h6 class="border-bottom pb-2 mb-3 text-primary">판매 기간</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">시작일</label>
                            <input type="datetime-local" class="form-control" @bind="editingGacha.start_date" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">종료일</label>
                            <input type="datetime-local" class="form-control" @bind="editingGacha.end_date" />
                            <div class="form-text">비워두면 무기한</div>
                        </div>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">취소</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveGacha">
                        @(isNew ? "신규 등록" : "수정 저장")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<MasterGachaDto> gachas;
    private string searchText = "";

    private bool showModal = false;
    private bool isNew = false;
    private MasterGachaDto editingGacha;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        gachas = await _gameClient.getGachas();
        if (!string.IsNullOrEmpty(searchText))
        {
            await SearchGachas();
        }
    }

    private async Task SearchGachas()
    {
        if (gachas == null || gachas.Count == 0) await LoadData();

        var query = gachas.AsQueryable();

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            if (int.TryParse(searchText, out int searchId))
            {
                query = query.Where(g => g.gacha_id == searchId);
            }
            else
            {
                query = query.Where(g => g.gacha_name.Contains(searchText));
            }
        }

        gachas = query.OrderBy(g => g.show_order).ThenBy(g => g.gacha_id).ToList();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchGachas();
    }

    private async Task ResetSearch()
    {
        searchText = "";
        await LoadData();
    }

    private void OpenAddModal()
    {
        isNew = true;
        editingGacha = new MasterGachaDto
        {
            gacha_id = 0,
            show_order = 1,
            gacha_type = (int)GachaType.BASIC,
            start_date = DateTime.Now,
            end_date = null,
            insert_date = DateTime.Now,
            update_date = DateTime.Now
        };
        showModal = true;
    }

    private void OpenEditModal(MasterGachaDto item)
    {
        isNew = false;
        editingGacha = new MasterGachaDto
        {
            gacha_id = item.gacha_id,
            gacha_name = item.gacha_name,
            show_order = item.show_order,
            gacha_type = item.gacha_type,
            gacha_lot_group_id = item.gacha_lot_group_id,
            gacha_consume_value = item.gacha_consume_value,
            gacha_coupon_item_id = item.gacha_coupon_item_id,
            gacha_image = item.gacha_image,
            gacha_detail_image = item.gacha_detail_image,
            gacha_detail_html = item.gacha_detail_html,
            gacha_point = item.gacha_point,
            gacha_bonus_reward_group_lot_id = item.gacha_bonus_reward_group_lot_id,
            gacha_exec_10_id = item.gacha_exec_10_id,
            start_date = item.start_date,
            end_date = item.end_date,
            insert_date = item.insert_date,
            update_date = item.update_date
        };
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        editingGacha = null;
    }

    private async Task SaveGacha()
    {
        try
        {
            (bool success, string message) result;

            if (isNew)
            {
                result = await _gameClient.addGachaAsync(editingGacha);
            }
            else
            {
                result = await _gameClient.editGachaAsync(editingGacha);
            }

            if (result.success)
            {
                await JS.InvokeVoidAsync("alert", result.message);
                CloseModal();
                await LoadData();
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"저장 실패: {result.message}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"오류 발생: {ex.Message}");
        }
    }
}