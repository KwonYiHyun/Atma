@page "/master/loginbonusdays"

@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using AdminTool.API
@using SharedData.Dto.Admin

@inject GameServerClient _gameClient
@inject IJSRuntime JS

<style>
    .table-scroll-container {
        height: calc(100vh - 250px);
        overflow-y: auto;
        border: 1px solid #dee2e6;
    }

        .table-scroll-container thead th {
            position: sticky;
            top: 0;
            z-index: 1;
        }

    .fab-btn {
        position: fixed;
        bottom: 30px;
        right: 30px;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        font-size: 30px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.3);
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding-bottom: 5px;
    }

    .day-badge {
        font-size: 1rem;
        padding: 0.4rem 0.6rem;
    }
</style>

<h3>일차별 출석 보상(Login Bonus Day) 관리</h3>

<div class="row mb-3">
    <div class="col-md-6">
        <div class="input-group">
            <input type="text" class="form-control" placeholder="출석부 테마 ID 검색 (예: 1001)"
                   @bind="searchText" @bind:event="oninput" @onkeyup="HandleKeyUp" />
            <button class="btn btn-primary" @onclick="SearchDays">검색</button>
            <button class="btn btn-secondary" @onclick="ResetSearch">초기화</button>
        </div>
        <div class="form-text mt-1">출석부 테마 ID를 입력하면 해당 출석부의 전체 일차 보상을 볼 수 있습니다.</div>
    </div>
</div>

@if (dayList == null)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="table-scroll-container bg-white">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark sticky-top">
                <tr>
                    <th style="width: 80px;">PK ID</th>
                    <th>출석부 테마 ID</th>
                    <th>출석 일차 (Day)</th>
                    <th>지급 보상 ID (Reward)</th>
                    <th>유효 기간</th>
                    <th style="width: 80px;">관리</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in dayList)
                {
                    <tr>
                        <td>@item.daily_login_bonus_day_id</td>
                        <td class="fw-bold text-primary">@item.daily_login_bonus_id</td>
                        <td>
                            <span class="badge bg-success day-badge">@item.total_login_count 일차</span>
                        </td>
                        <td>
                            <span class="fw-bold">🎁 Reward ID: @item.reward_id_1</span>
                        </td>
                        <td>
                            <small>
                                🟢 @item.start_date.ToString("yy-MM-dd HH:mm") <br />
                                🔴 @(item.end_date.HasValue? item.end_date.Value.ToString("yy-MM-dd HH:mm") : "무기한")
                            </small>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-info text-white" @onclick="() => OpenEditModal(item)">
                                상세
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<button class="btn btn-primary fab-btn" @onclick="OpenAddModal" title="신규 출석 보상 추가"> + </button>

@if (showModal && editingDay != null)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @(isNew ? "신규 일차별 보상 등록" : $"보상 데이터 수정 ({editingDay.daily_login_bonus_day_id})")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">

                    <h6 class="border-bottom pb-2 mb-3 text-primary">기본 식별 정보</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">PK ID (Auto)</label>
                            <input type="number" class="form-control" @bind="editingDay.daily_login_bonus_day_id" disabled="@(!isNew)" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold text-primary">출석부 테마 ID</label>
                            <input type="number" class="form-control" @bind="editingDay.daily_login_bonus_id" />
                            <div class="form-text">MasterDailyLoginBonus 테이블의 ID</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold text-success">누적 출석 일수 (Day)</label>
                            <div class="input-group">
                                <input type="number" class="form-control" @bind="editingDay.total_login_count" />
                                <span class="input-group-text">일차</span>
                            </div>
                        </div>
                    </div>

                    <h6 class="border-bottom pb-2 mb-3 text-primary">지급 보상 설정</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">보상 ID (Reward ID)</label>
                            <div class="input-group">
                                <span class="input-group-text">🎁</span>
                                <input type="number" class="form-control" @bind="editingDay.reward_id_1" />
                            </div>
                            <div class="form-text">MasterReward 테이블의 ID를 입력하세요.</div>
                        </div>
                    </div>

                    <h6 class="border-bottom pb-2 mb-3 text-primary">유효 기간 (테마 기간과 맞추는 것 권장)</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">시작일</label>
                            <input type="datetime-local" class="form-control" @bind="editingDay.start_date" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">종료일</label>
                            <input type="datetime-local" class="form-control" @bind="editingDay.end_date" />
                            <div class="form-text">비워두면 무기한</div>
                        </div>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">취소</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveDay">
                        @(isNew ? "신규 등록" : "수정 저장")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<MasterDailyLoginBonusDayDto> dayList;
    private string searchText = "";

    private bool showModal = false;
    private bool isNew = false;
    private MasterDailyLoginBonusDayDto editingDay;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        dayList = await _gameClient.getLoginBonusDays();
        if (!string.IsNullOrEmpty(searchText))
        {
            await SearchDays();
        }
    }

    private async Task SearchDays()
    {
        if (dayList == null || dayList.Count == 0) await LoadData();

        var query = dayList.AsQueryable();

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            if (int.TryParse(searchText, out int searchId))
            {
                query = query.Where(d => d.daily_login_bonus_id == searchId);
            }
        }

        dayList = query.OrderBy(d => d.daily_login_bonus_id)
                       .ThenBy(d => d.total_login_count)
                       .ToList();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchDays();
    }

    private async Task ResetSearch()
    {
        searchText = "";
        await LoadData();
    }

    private void OpenAddModal()
    {
        isNew = true;
        editingDay = new MasterDailyLoginBonusDayDto
        {
            daily_login_bonus_day_id = 0,
            daily_login_bonus_id = 0,
            total_login_count = 1,
            reward_id_1 = 0,
            start_date = DateTime.Now,
            end_date = null,
            insert_date = DateTime.Now,
            update_date = DateTime.Now
        };
        showModal = true;
    }

    private void OpenEditModal(MasterDailyLoginBonusDayDto item)
    {
        isNew = false;
        editingDay = new MasterDailyLoginBonusDayDto
        {
            daily_login_bonus_day_id = item.daily_login_bonus_day_id,
            daily_login_bonus_id = item.daily_login_bonus_id,
            total_login_count = item.total_login_count,
            reward_id_1 = item.reward_id_1,
            start_date = item.start_date,
            end_date = item.end_date,
            insert_date = item.insert_date,
            update_date = item.update_date
        };
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        editingDay = null;
    }

    private async Task SaveDay()
    {
        try
        {
            (bool success, string message) result;

            if (isNew)
            {
                result = await _gameClient.addLoginBonusDayAsync(editingDay);
            }
            else
            {
                result = await _gameClient.editLoginBonusDayAsync(editingDay);
            }

            if (result.success)
            {
                await JS.InvokeVoidAsync("alert", result.message);
                CloseModal();
                await LoadData();
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"저장 실패: {result.message}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"오류 발생: {ex.Message}");
        }
    }
}