@page "/master/items"

@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using AdminTool.API
@using SharedData.Dto.Admin
@using SharedData.Models
@using SharedData.Type

@inject GameServerClient _gameClient;
@inject IJSRuntime JS

<style>
    .table-scroll-container {
        height: calc(100vh - 250px);
        overflow-y: auto;
        border: 1px solid #dee2e6;
    }

        .table-scroll-container thead th {
            position: sticky;
            top: 0;
            z-index: 1;
        }

    .fab-btn {
        position: fixed;
        bottom: 30px;
        right: 30px;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        font-size: 30px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.3);
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding-bottom: 5px;
    }
</style>

<h3>아이템 마스터 관리</h3>

<div class="row mb-3">
    <div class="col-md-6">
        <div class="input-group">
            <input type="text" class="form-control" placeholder="아이템 ID 또는 이름 검색"
                   @bind="searchText" @bind:event="oninput" @onkeyup="HandleKeyUp" />
            <button class="btn btn-primary" @onclick="SearchItems">검색</button>
            <button class="btn btn-secondary" @onclick="ResetSearch">초기화</button>
        </div>
    </div>
</div>

@if (items == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="table-scroll-container bg-white">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark sticky-top">
                <tr>
                    <th style="width: 80px;">ID</th>
                    <th>이름</th>
                    <th>타입</th>
                    <th>탭</th>
                    <th>설명</th>
                    <th style="width: 100px;">관리</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in items)
                {
                    <tr>
                        <td>@item.item_id</td>
                        <td>@item.item_name</td>
                        <td>
                            @switch ((ItemType)item.item_type)
                            {
                                case ItemType.GACHA_TICKET:
                                    <span class="badge bg-info text-dark">티켓</span>
                                    break;
                                case ItemType.GACHA_POINT:
                                    <span class="badge bg-warning text-dark">포인트</span>
                                    break;
                                case ItemType.CHARACTER_PIECE:
                                    <span class="badge bg-primary">조각</span>
                                    break;
                                case ItemType.CHARACTER_REINFORCEMENT_MATERIAL:
                                    <span class="badge bg-secondary">강화재료</span>
                                    break;
                                default:
                                    <span class="badge bg-light text-dark">기타(@item.item_type)</span>
                                    break;
                            }
                        </td>
                        <td>@item.tab_type</td>
                        <td class="text-truncate" style="max-width: 200px;">@item.item_description</td>
                        <td>
                            <button class="btn btn-sm btn-info text-white" @onclick="() => OpenEditModal(item)">
                                상세
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<button class="btn btn-primary fab-btn" @onclick="OpenAddModal" title="아이템 추가">
    +
</button>

@if (showModal && editingItem != null)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @(isNewItem ? "아이템 신규 추가" : $"아이템 수정 ({editingItem.item_id})")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">아이템 ID (PK)</label>
                            <input type="number" class="form-control" @bind="editingItem.item_id" disabled="@(!isNewItem)" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label fw-bold">아이템 이름</label>
                            <input type="text" class="form-control" @bind="editingItem.item_name" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">표시 순서</label>
                            <input type="number" class="form-control" @bind="editingItem.show_order" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold">Item Type</label>
                            <select class="form-select" @bind="editingItem.item_type">
                                @foreach (ItemType type in Enum.GetValues(typeof(ItemType)))
                                {
                                    <option value="@((int)type)">@type.ToString()</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Tab Type</label>
                            <input type="number" class="form-control" @bind="editingItem.tab_type" />
                        </div>

                        <div class="col-12">
                            <label class="form-label">이미지 파일명</label>
                            <input type="text" class="form-control" @bind="editingItem.item_image_name" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Param 1</label>
                            <input type="number" class="form-control" @bind="editingItem.item_param_1" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Param 2</label>
                            <input type="number" class="form-control" @bind="editingItem.item_param_2" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">시작일</label>
                            <input type="datetime-local" class="form-control" @bind="editingItem.start_date" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">종료일</label>
                            <input type="datetime-local" class="form-control" @bind="editingItem.end_date" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">만료일</label>
                            <input type="datetime-local" class="form-control" @bind="editingItem.expire_date" />
                        </div>

                        <div class="col-12">
                            <label class="form-label">설명</label>
                            <textarea class="form-control" rows="3" @bind="editingItem.item_description"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">취소</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveItem">
                        @(isNewItem ? "신규 등록" : "수정 저장")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<MasterItemDto> items;
    private string searchText = "";

    private bool showModal = false;
    private bool isNewItem = false;
    private MasterItemDto editingItem;

    protected override async Task OnInitializedAsync()
    {
        await LoadAllItems();
    }

    private async Task LoadAllItems()
    {
        items = await _gameClient.getItems();
        if (!string.IsNullOrEmpty(searchText))
        {
            await SearchItems();
        }
    }

    private async Task SearchItems()
    {
        if (items == null || items.Count == 0) await LoadAllItems();

        var query = items.AsQueryable();

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            if (int.TryParse(searchText, out int searchId))
            {
                query = query.Where(i => i.item_id == searchId);
            }
            else
            {
                query = query.Where(i => i.item_name.Contains(searchText));
            }
        }

        items = query.OrderBy(i => i.item_id).ToList();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchItems();
    }

    private async Task ResetSearch()
    {
        searchText = "";
        await LoadAllItems();
    }

    private void OpenAddModal()
    {
        isNewItem = true;
        editingItem = new MasterItemDto
        {
            item_id = 0,
            item_type = (int)ItemType.CHARACTER_REINFORCEMENT_MATERIAL,
            start_date = DateTime.Today,
            end_date = DateTime.Today.AddYears(10),
            insert_date = DateTime.Now,
            update_date = DateTime.Now
        };
        showModal = true;
    }

    private void OpenEditModal(MasterItemDto item)
    {
        isNewItem = false;
        editingItem = new MasterItemDto
        {
            item_id = item.item_id,
            item_name = item.item_name,
            show_order = item.show_order,
            item_type = item.item_type,
            tab_type = item.tab_type,
            item_param_1 = item.item_param_1,
            item_param_2 = item.item_param_2,
            item_description = item.item_description,
            item_image_name = item.item_image_name,
            start_date = item.start_date,
            end_date = item.end_date,
            expire_date = item.expire_date,
            insert_date = item.insert_date,
            update_date = item.update_date
        };
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        editingItem = null;
    }

    private async Task SaveItem()
    {
        try
        {
            (bool success, string message) result;

            if (isNewItem)
            {
                result = await _gameClient.addItemAsync(editingItem);
            }
            else
            {
                result = await _gameClient.editItemAsync(editingItem);
            }

            if (result.success)
            {
                await JS.InvokeVoidAsync("alert", isNewItem ? "추가되었습니다." : "수정되었습니다.");
                CloseModal();
                await LoadAllItems();
                await SearchItems();
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"저장 실패: {result.message}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"오류 발생: {ex.Message}");
        }
    }
}