@page "/master/rewards"

@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using AdminTool.API
@using SharedData.Dto.Admin
@using SharedData.Type

@inject GameServerClient _gameClient
@inject IJSRuntime JS

<style>
    .table-scroll-container {
        height: calc(100vh - 250px);
        overflow-y: auto;
        border: 1px solid #dee2e6;
    }

        .table-scroll-container thead th {
            position: sticky;
            top: 0;
            z-index: 1;
        }

    .fab-btn {
        position: fixed;
        bottom: 30px;
        right: 30px;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        font-size: 30px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.3);
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding-bottom: 5px;
    }
</style>

<h3>보상(Reward) 마스터 관리</h3>

<div class="row mb-3">
    <div class="col-md-6">
        <div class="input-group">
            <input type="text" class="form-control" placeholder="ID 검색"
                   @bind="searchText" @bind:event="oninput" @onkeyup="HandleKeyUp" />
            <button class="btn btn-primary" @onclick="SearchRewards">검색</button>
            <button class="btn btn-secondary" @onclick="ResetSearch">초기화</button>
        </div>
    </div>
</div>

@if (rewardList == null)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="table-scroll-container bg-white">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark sticky-top">
                <tr>
                    <th style="width: 80px;">ID</th>
                    <th>타입 (Object Type)</th>
                    <th>대상 ID (Value)</th>
                    <th>수량 (Amount)</th>
                    <th>추가 파라미터</th>
                    <th>기간</th>
                    <th style="width: 100px;">관리</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reward in rewardList)
                {
                    <tr>
                        <td>@reward.reward_id</td>
                        <td>
                            @switch ((ObjectType)reward.object_type)
                            {
                                case ObjectType.ITEM:
                                    <span class="badge bg-primary">아이템</span>
                                    break;
                                case ObjectType.CHARACTER:

                                    <span class="badge bg-success">캐릭터</span>
                                    break;
                                case ObjectType.PRISM:

                                    <span class="badge bg-info text-dark">재화(Prism)</span>
                                    break;
                                case ObjectType.TOKEN:

                                    <span class="badge bg-warning text-dark">토큰</span>
                                    break;
                                case ObjectType.FILM:

                                    <span class="badge bg-secondary">필름</span>
                                    break;
                                default:

                                    <span class="badge bg-light text-dark">기타(@reward.object_type)</span>
                                    break;
                            }
                        </td>
                        <td>
                            @reward.object_value
                            <small class="text-muted ms-1">
                                @if (reward.object_type == (int)ObjectType.ITEM)
                                {
                                    <span>(Item ID)</span>
                                }
                                else if (reward.object_type == (int)ObjectType.CHARACTER)
                                {

                                    <span>(Char ID)</span>
                                }
                            </small>
                        </td>
                        <td><strong>@reward.object_amount.ToString("N0")</strong></td>
                        <td>@reward.additional_param</td>
                        <td>
                            <small>
                                @reward.start_date.ToString("yy-MM-dd HH:mm") <br />
                                @(reward.end_date.HasValue? reward.end_date.Value.ToString("yy-MM-dd HH:mm") : "무기한")
                            </small>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-info text-white" @onclick="() => OpenEditModal(reward)">
                                상세
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<button class="btn btn-primary fab-btn" @onclick="OpenAddModal" title="신규 보상 추가"> + </button>

@if (showModal && editingReward != null)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @(isNew ? "신규 보상 등록" : $"보상 수정 ({editingReward.reward_id})")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">ID (PK)</label>
                            <input type="number" class="form-control" @bind="editingReward.reward_id" disabled="@(!isNew)" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">시작일</label>
                            <input type="datetime-local" class="form-control" @bind="editingReward.start_date" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">종료일</label>
                            <input type="datetime-local" class="form-control" @bind="editingReward.end_date" />
                        </div>

                        <hr class="my-4" />

                        <div class="col-md-4">
                            <label class="form-label fw-bold">보상 타입 (Object Type)</label>
                            <select class="form-select" @bind="editingReward.object_type">
                                @foreach (ObjectType type in Enum.GetValues(typeof(ObjectType)))
                                {
                                    <option value="@((int)type)">@type.ToString()</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold">대상 ID (Object Value)</label>
                            <input type="number" class="form-control" @bind="editingReward.object_value" />
                            <div class="form-text">
                                @if (editingReward.object_type == (int)ObjectType.ITEM)
                                {
                                    <span>지급할 아이템의 ID를 입력하세요.</span>
                                }
                                else if (editingReward.object_type == (int)ObjectType.CHARACTER)
                                {

                                    <span>지급할 캐릭터의 ID를 입력하세요.</span>
                                }
                                else
                                {

                                    <span>재화나 기타 타입일 경우 0 또는 해당 ID</span>
                                }
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold">지급 수량 (Amount)</label>
                            <input type="number" class="form-control" @bind="editingReward.object_amount" />
                        </div>

                        <div class="col-12">
                            <label class="form-label">추가 파라미터 (Additional Param)</label>
                            <input type="text" class="form-control" @bind="editingReward.additional_param" placeholder="예: JSON 데이터 또는 메모" />
                        </div>

                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">취소</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveReward">
                        @(isNew ? "신규 등록" : "수정 저장")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<MasterRewardDto> rewardList;
    private string searchText = "";

    private bool showModal = false;
    private bool isNew = false;
    private MasterRewardDto editingReward;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        rewardList = await _gameClient.getRewards();
        if (!string.IsNullOrEmpty(searchText))
        {
            await SearchRewards();
        }
    }

    private async Task SearchRewards()
    {
        if (rewardList == null || rewardList.Count == 0) await LoadData();

        var query = rewardList.AsQueryable();

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            if (int.TryParse(searchText, out int searchId))
            {
                query = query.Where(r => r.reward_id == searchId || r.object_value == searchId);
            }
            else
            {
                query = query.Where(r => r.additional_param != null && r.additional_param.Contains(searchText));
            }
        }

        rewardList = query.OrderByDescending(r => r.reward_id).ToList();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchRewards();
    }

    private async Task ResetSearch()
    {
        searchText = "";
        await LoadData();
    }

    private void OpenAddModal()
    {
        isNew = true;
        editingReward = new MasterRewardDto
        {
            reward_id = 0,
            object_type = (int)ObjectType.ITEM,
            object_value = 0,
            object_amount = 1,
            start_date = DateTime.Now,
            end_date = null, // 기본 무기한
            insert_date = DateTime.Now,
            update_date = DateTime.Now
        };
        showModal = true;
    }

    private void OpenEditModal(MasterRewardDto item)
    {
        isNew = false;
        editingReward = new MasterRewardDto
        {
            reward_id = item.reward_id,
            object_type = item.object_type,
            object_value = item.object_value,
            object_amount = item.object_amount,
            additional_param = item.additional_param,
            start_date = item.start_date,
            end_date = item.end_date,
            insert_date = item.insert_date,
            update_date = item.update_date
        };
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        editingReward = null;
    }

    private async Task SaveReward()
    {
        try
        {
            (bool success, string message) result;

            if (isNew)
            {
                result = await _gameClient.addRewardAsync(editingReward);
            }
            else
            {
                result = await _gameClient.editRewardAsync(editingReward);
            }

            if (result.success)
            {
                await JS.InvokeVoidAsync("alert", result.message);
                CloseModal();
                await LoadData();
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"저장 실패: {result.message}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"오류 발생: {ex.Message}");
        }
    }
}