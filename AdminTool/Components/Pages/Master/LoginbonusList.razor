@page "/master/loginbonuses"

@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using AdminTool.API
@using SharedData.Dto.Admin

@inject GameServerClient _gameClient
@inject IJSRuntime JS

<style>
    .table-scroll-container {
        height: calc(100vh - 250px);
        overflow-y: auto;
        border: 1px solid #dee2e6;
    }

        .table-scroll-container thead th {
            position: sticky;
            top: 0;
            z-index: 1;
        }

    .fab-btn {
        position: fixed;
        bottom: 30px;
        right: 30px;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        font-size: 30px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.3);
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding-bottom: 5px;
    }

    .img-preview {
        max-width: 120px;
        max-height: 50px;
        object-fit: contain;
        border: 1px solid #ddd;
        border-radius: 4px;
        background-color: #f8f9fa;
    }
</style>

<h3>출석부(Login Bonus) 테마 관리</h3>

<div class="row mb-3">
    <div class="col-md-6">
        <div class="input-group">
            <input type="text" class="form-control" placeholder="ID 또는 출석부 타이틀 검색"
                   @bind="searchText" @bind:event="oninput" @onkeyup="HandleKeyUp" />
            <button class="btn btn-primary" @onclick="SearchBonuses">검색</button>
            <button class="btn btn-secondary" @onclick="ResetSearch">초기화</button>
        </div>
    </div>
</div>

@if (bonusList == null)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="table-scroll-container bg-white">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark sticky-top">
                <tr>
                    <th style="width: 80px;">ID</th>
                    <th>출석부 타이틀</th>
                    <th>배경 이미지</th>
                    <th>진행 기간</th>
                    <th style="width: 80px;">관리</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in bonusList)
                {
                    <tr>
                        <td class="fw-bold text-primary">@item.daily_login_bonus_id</td>
                        <td class="fw-bold">@item.title_text</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.back_image))
                            {
                                <img src="@item.back_image" class="img-preview" onerror="this.style.display='none'" />
                                <div class="small text-muted text-truncate" style="max-width: 200px;">@item.back_image</div>
                            }
                            else
                            {
                                <span class="text-muted small">-</span>
                            }
                        </td>
                        <td>
                            <small>
                                🟢 시작: @item.start_date.ToString("yyyy-MM-dd HH:mm") <br />
                                🔴 종료: @(item.end_date.HasValue? item.end_date.Value.ToString("yyyy-MM-dd HH:mm") : "무기한 (상시)")
                            </small>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-info text-white" @onclick="() => OpenEditModal(item)">
                                상세
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<button class="btn btn-primary fab-btn" @onclick="OpenAddModal" title="신규 출석부 추가"> + </button>

@if (showModal && editingBonus != null)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @(isNew ? "신규 출석부 등록" : $"출석부 수정 ({editingBonus.daily_login_bonus_id})")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">

                    <h6 class="border-bottom pb-2 mb-3 text-primary">기본 정보</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">출석부 ID (PK)</label>
                            <input type="number" class="form-control" @bind="editingBonus.daily_login_bonus_id" disabled="@(!isNew)" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label fw-bold">출석부 타이틀 (Title Text)</label>
                            <input type="text" class="form-control" @bind="editingBonus.title_text" placeholder="예: 신규 유저 환영 7일 출석부" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">배경 이미지 경로 (Back Image)</label>
                            <div class="input-group">
                                <input type="text" class="form-control" @bind="editingBonus.back_image" placeholder="Assets/UI/LoginBonus/..." />
                                @if (!string.IsNullOrEmpty(editingBonus.back_image))
                                {
                                    <span class="input-group-text p-0 overflow-hidden bg-light">
                                        <img src="@editingBonus.back_image" style="height:38px; max-width:100px; object-fit:contain;" onerror="this.style.display='none'" />
                                    </span>
                                }
                            </div>
                        </div>
                    </div>

                    <h6 class="border-bottom pb-2 mb-3 text-primary">노출/진행 기간 설정</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">시작일 (Start Date)</label>
                            <input type="datetime-local" class="form-control" @bind="editingBonus.start_date" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">종료일 (End Date)</label>
                            <input type="datetime-local" class="form-control" @bind="editingBonus.end_date" />
                            <div class="form-text">상시 출석부인 경우 비워두세요.</div>
                        </div>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">취소</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveBonus">
                        @(isNew ? "신규 등록" : "수정 저장")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<MasterDailyLoginBonusDto> bonusList;
    private string searchText = "";

    private bool showModal = false;
    private bool isNew = false;
    private MasterDailyLoginBonusDto editingBonus;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        bonusList = await _gameClient.getLoginBonuses();
        if (!string.IsNullOrEmpty(searchText))
        {
            await SearchBonuses();
        }
    }

    private async Task SearchBonuses()
    {
        if (bonusList == null || bonusList.Count == 0) await LoadData();

        var query = bonusList.AsQueryable();

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            if (int.TryParse(searchText, out int searchId))
            {
                query = query.Where(b => b.daily_login_bonus_id == searchId);
            }
            else
            {
                query = query.Where(b => b.title_text.Contains(searchText));
            }
        }

        bonusList = query.OrderByDescending(b => b.start_date)
                         .ThenByDescending(b => b.daily_login_bonus_id)
                         .ToList();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchBonuses();
    }

    private async Task ResetSearch()
    {
        searchText = "";
        await LoadData();
    }

    private void OpenAddModal()
    {
        isNew = true;
        editingBonus = new MasterDailyLoginBonusDto
        {
            daily_login_bonus_id = 0,
            title_text = "",
            back_image = "",
            start_date = DateTime.Now,
            end_date = null,
            insert_date = DateTime.Now,
            update_date = DateTime.Now
        };
        showModal = true;
    }

    private void OpenEditModal(MasterDailyLoginBonusDto item)
    {
        isNew = false;
        editingBonus = new MasterDailyLoginBonusDto
        {
            daily_login_bonus_id = item.daily_login_bonus_id,
            title_text = item.title_text,
            back_image = item.back_image,
            start_date = item.start_date,
            end_date = item.end_date,
            insert_date = item.insert_date,
            update_date = item.update_date
        };
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        editingBonus = null;
    }

    private async Task SaveBonus()
    {
        try
        {
            (bool success, string message) result;

            if (isNew)
            {
                result = await _gameClient.addLoginBonusAsync(editingBonus);
            }
            else
            {
                result = await _gameClient.editLoginBonusAsync(editingBonus);
            }

            if (result.success)
            {
                await JS.InvokeVoidAsync("alert", result.message);
                CloseModal();
                await LoadData();
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"저장 실패: {result.message}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"오류 발생: {ex.Message}");
        }
    }
}