@page "/master/mails"

@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using AdminTool.API
@using SharedData.Dto.Admin

@inject GameServerClient _gameClient
@inject IJSRuntime JS

<style>
    .table-scroll-container {
        height: calc(100vh - 250px);
        overflow-y: auto;
        border: 1px solid #dee2e6;
    }

        .table-scroll-container thead th {
            position: sticky;
            top: 0;
            z-index: 1;
        }

    .fab-btn {
        position: fixed;
        bottom: 30px;
        right: 30px;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        font-size: 30px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.3);
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding-bottom: 5px;
    }

    .mail-body-preview {
        font-size: 0.85rem;
        color: #6c757d;
        max-width: 300px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>

<h3>우편 템플릿(Mail) 관리</h3>

<div class="row mb-3">
    <div class="col-md-6">
        <div class="input-group">
            <input type="text" class="form-control" placeholder="ID 또는 우편 제목 검색"
                   @bind="searchText" @bind:event="oninput" @onkeyup="HandleKeyUp" />
            <button class="btn btn-primary" @onclick="SearchMails">검색</button>
            <button class="btn btn-secondary" @onclick="ResetSearch">초기화</button>
        </div>
    </div>
</div>

@if (mailList == null)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="table-scroll-container bg-white">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark sticky-top">
                <tr>
                    <th style="width: 80px;">ID</th>
                    <th>발신자 (Sender)</th>
                    <th>우편 제목 / 내용</th>
                    <th>중요도</th>
                    <th>기간</th>
                    <th style="width: 80px;">관리</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in mailList)
                {
                    <tr>
                        <td class="fw-bold">@item.mail_id</td>
                        <td>
                            @switch (item.sender_type)
                            {
                                case 1:
                                    <span class="badge bg-primary">운영자</span>
                                    break;
                                case 2:

                                    <span class="badge bg-secondary">시스템</span>
                                    break;
                                case 3:

                                    <span class="badge bg-success">이벤트</span>
                                    break;
                                default:

                                    <span class="badge bg-light text-dark">기타(@item.sender_type)</span>
                                    break;
                            }
                        </td>
                        <td>
                            <div class="fw-bold text-dark">@item.mail_subject</div>
                            <div class="mail-body-preview">@item.mail_body</div>
                        </td>
                        <td>
                            @if (item.important_flag == 1)
                            {
                                <span class="badge bg-danger">⭐ 중요</span>
                            }
                            else
                            {
                                <span class="badge bg-light text-dark border">일반</span>
                            }
                        </td>
                        <td>
                            <small>
                                @item.start_date.ToString("yy-MM-dd") <br />
                                @(item.end_date.HasValue? item.end_date.Value.ToString("yy-MM-dd") : "무기한")
                            </small>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-info text-white" @onclick="() => OpenEditModal(item)">
                                상세
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<button class="btn btn-primary fab-btn" @onclick="OpenAddModal" title="신규 우편 추가"> + </button>

@if (showModal && editingMail != null)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @(isNew ? "신규 우편 등록" : $"우편 수정 ({editingMail.mail_id})")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">

                    <h6 class="border-bottom pb-2 mb-3 text-primary">기본 속성 설정</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">ID (PK)</label>
                            <input type="number" class="form-control" @bind="editingMail.mail_id" disabled="@(!isNew)" />
                            <div class="form-text">지급 로직에서 참조할 ID</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">발신자 타입 (Sender)</label>
                            <select class="form-select" @bind="editingMail.sender_type">
                                <option value="1">운영자 (GM)</option>
                                <option value="2">시스템 (System)</option>
                                <option value="3">이벤트 (Event)</option>
                                <option value="99">기타</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">중요 우편 여부 (Important)</label>
                            <select class="form-select" @bind="editingMail.important_flag">
                                <option value="0">일반 우편</option>
                                <option value="1">중요 우편 (⭐)</option>
                            </select>
                        </div>
                    </div>

                    <h6 class="border-bottom pb-2 mb-3 text-primary">우편 내용 작성</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-12">
                            <label class="form-label fw-bold">우편 제목 (Subject)</label>
                            <input type="text" class="form-control" @bind="editingMail.mail_subject" placeholder="예: 서버 점검 보상 지급 안내" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">우편 본문 (Body)</label>
                            <textarea class="form-control" rows="6" @bind="editingMail.mail_body" placeholder="유저에게 보여질 본문 내용을 입력하세요."></textarea>
                        </div>
                    </div>

                    <h6 class="border-bottom pb-2 mb-3 text-primary">사용 유효 기간</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">시작일</label>
                            <input type="datetime-local" class="form-control" @bind="editingMail.start_date" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">종료일</label>
                            <input type="datetime-local" class="form-control" @bind="editingMail.end_date" />
                            <div class="form-text">비워두면 상시 사용 가능한 템플릿입니다.</div>
                        </div>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">취소</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveMail">
                        @(isNew ? "신규 등록" : "수정 저장")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<MasterMailDto> mailList;
    private string searchText = "";

    private bool showModal = false;
    private bool isNew = false;
    private MasterMailDto editingMail;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        mailList = await _gameClient.getMails();
        if (!string.IsNullOrEmpty(searchText))
        {
            await SearchMails();
        }
    }

    private async Task SearchMails()
    {
        if (mailList == null || mailList.Count == 0) await LoadData();

        var query = mailList.AsQueryable();

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            if (int.TryParse(searchText, out int searchId))
            {
                query = query.Where(m => m.mail_id == searchId);
            }
            else
            {
                query = query.Where(m => m.mail_subject.Contains(searchText) || m.mail_body.Contains(searchText));
            }
        }

        mailList = query.OrderByDescending(m => m.update_date).ThenByDescending(m => m.mail_id).ToList();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchMails();
    }

    private async Task ResetSearch()
    {
        searchText = "";
        await LoadData();
    }

    private void OpenAddModal()
    {
        isNew = true;
        editingMail = new MasterMailDto
        {
            mail_id = 0,
            sender_type = 1,
            important_flag = 0,
            mail_subject = "",
            mail_body = "",
            start_date = DateTime.Now,
            end_date = null,
            insert_date = DateTime.Now,
            update_date = DateTime.Now
        };
        showModal = true;
    }

    private void OpenEditModal(MasterMailDto item)
    {
        isNew = false;
        editingMail = new MasterMailDto
        {
            mail_id = item.mail_id,
            sender_type = item.sender_type,
            mail_subject = item.mail_subject,
            mail_body = item.mail_body,
            important_flag = item.important_flag,
            start_date = item.start_date,
            end_date = item.end_date,
            insert_date = item.insert_date,
            update_date = item.update_date
        };
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        editingMail = null;
    }

    private async Task SaveMail()
    {
        try
        {
            (bool success, string message) result;

            if (isNew)
            {
                result = await _gameClient.addMailAsync(editingMail);
            }
            else
            {
                result = await _gameClient.editMailAsync(editingMail);
            }

            if (result.success)
            {
                await JS.InvokeVoidAsync("alert", result.message);
                CloseModal();
                await LoadData();
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"저장 실패: {result.message}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"오류 발생: {ex.Message}");
        }
    }
}