@page "/master/notices"

@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using AdminTool.API
@using SharedData.Dto.Admin

@inject GameServerClient _gameClient
@inject IJSRuntime JS

<style>
    .table-scroll-container {
        height: calc(100vh - 250px);
        overflow-y: auto;
        border: 1px solid #dee2e6;
    }

        .table-scroll-container thead th {
            position: sticky;
            top: 0;
            z-index: 1;
        }

    .fab-btn {
        position: fixed;
        bottom: 30px;
        right: 30px;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        font-size: 30px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.3);
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding-bottom: 5px;
    }
    .banner-preview {
        height: 40px;
        width: auto;
        max-width: 120px;
        object-fit: cover;
        border: 1px solid #ddd;
        border-radius: 4px;
    }
</style>

<h3>공지사항(Notice) 관리</h3>

<div class="row mb-3">
    <div class="col-md-6">
        <div class="input-group">
            <input type="text" class="form-control" placeholder="ID 또는 제목 검색"
                   @bind="searchText" @bind:event="oninput" @onkeyup="HandleKeyUp" />
            <button class="btn btn-primary" @onclick="SearchNotices">검색</button>
            <button class="btn btn-secondary" @onclick="ResetSearch">초기화</button>
        </div>
    </div>
</div>

@if (noticeList == null)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="table-scroll-container bg-white">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark sticky-top">
                <tr>
                    <th style="width: 60px;">ID</th>
                    <th style="width: 60px;">순서</th>
                    <th>타입</th>
                    <th>배너</th>
                    <th>제목</th>
                    <th>링크/내용</th>
                    <th>기간</th>
                    <th style="width: 100px;">관리</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var notice in noticeList)
                {
                    <tr>
                        <td>@notice.notice_id</td>
                        <td>@notice.show_order</td>
                        <td>
                            @switch (notice.notice_type)
                            {
                                case 1:
                                    <span class="badge bg-primary">일반</span>
                                    break;
                                case 2:

                                    <span class="badge bg-warning text-dark">이벤트</span>
                                    break;
                                case 3:

                                    <span class="badge bg-danger">점검</span>
                                    break;
                                default:

                                    <span class="badge bg-secondary">기타(@notice.notice_type)</span>
                                    break;
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(notice.notice_banner_image))
                            {
                                <img src="@notice.notice_banner_image" class="banner-preview"
                                     onerror="this.style.display='none'" />
                            }
                            else
                            {
                                <span class="text-muted small">-</span>
                            }
                        </td>
                        <td class="fw-bold">@notice.notice_title</td>
                        <td>
                            <div class="text-truncate" style="max-width: 200px;">
                                @if (!string.IsNullOrEmpty(notice.notice_link))
                                {
                                    <span class="text-primary">🔗 @notice.notice_link</span>
                                }
                                else
                                {
                                    <span class="text-muted">@notice.notice_content</span>
                                }
                            </div>
                        </td>
                        <td>
                            <small>
                                @notice.start_date.ToString("yy-MM-dd HH:mm") <br />
                                @(notice.end_date.HasValue? notice.end_date.Value.ToString("yy-MM-dd HH:mm") : "무기한")
                            </small>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-info text-white" @onclick="() => OpenEditModal(notice)">
                                상세
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<button class="btn btn-primary fab-btn" @onclick="OpenAddModal" title="신규 공지 추가"> + </button>

@if (showModal && editingNotice != null)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @(isNew ? "신규 공지 등록" : $"공지 수정 ({editingNotice.notice_id})")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">

                    <h6 class="border-bottom pb-2 mb-3 text-primary">기본 설정</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-3">
                            <label class="form-label fw-bold">ID (PK)</label>
                            <input type="number" class="form-control" @bind="editingNotice.notice_id" disabled="@(!isNew)" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">노출 순서</label>
                            <input type="number" class="form-control" @bind="editingNotice.show_order" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">공지 타입</label>
                            <select class="form-select" @bind="editingNotice.notice_type">
                                <option value="1">일반 공지 (General)</option>
                                <option value="2">이벤트 (Event)</option>
                                <option value="3">점검 (Maintenance)</option>
                                <option value="99">기타 (Etc)</option>
                            </select>
                        </div>
                    </div>

                    <h6 class="border-bottom pb-2 mb-3 text-primary">내용 작성</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-12">
                            <label class="form-label fw-bold">제목</label>
                            <input type="text" class="form-control" @bind="editingNotice.notice_title" />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">배너 이미지 URL</label>
                            <div class="input-group">
                                <input type="text" class="form-control" @bind="editingNotice.notice_banner_image" placeholder="https://..." />
                                @if (!string.IsNullOrEmpty(editingNotice.notice_banner_image))
                                {
                                    <span class="input-group-text p-0 overflow-hidden">
                                        <img src="@editingNotice.notice_banner_image" style="height:38px;" onerror="this.style.display='none'" />
                                    </span>
                                }
                            </div>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">외부 링크 (클릭 시 이동)</label>
                            <input type="text" class="form-control" @bind="editingNotice.notice_link" placeholder="비워두면 이동 안함" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">본문 내용</label>
                            <textarea class="form-control" rows="5" @bind="editingNotice.notice_content" placeholder="텍스트 또는 HTML"></textarea>
                        </div>
                    </div>

                    <h6 class="border-bottom pb-2 mb-3 text-primary">게시 기간</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">시작일</label>
                            <input type="datetime-local" class="form-control" @bind="editingNotice.start_date" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">종료일</label>
                            <input type="datetime-local" class="form-control" @bind="editingNotice.end_date" />
                            <div class="form-text">비워두면 무기한</div>
                        </div>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">취소</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveNotice">
                        @(isNew ? "신규 등록" : "수정 저장")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<MasterNoticeDto> noticeList;
    private string searchText = "";

    private bool showModal = false;
    private bool isNew = false;
    private MasterNoticeDto editingNotice;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        noticeList = await _gameClient.getNotices();
        if (!string.IsNullOrEmpty(searchText))
        {
            await SearchNotices();
        }
    }

    private async Task SearchNotices()
    {
        if (noticeList == null || noticeList.Count == 0) await LoadData();

        var query = noticeList.AsQueryable();

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            if (int.TryParse(searchText, out int searchId))
            {
                query = query.Where(n => n.notice_id == searchId);
            }
            else
            {
                query = query.Where(n => n.notice_title.Contains(searchText));
            }
        }

        noticeList = query
            .OrderByDescending(n => n.start_date)
            .ThenBy(n => n.show_order)
            .ToList();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchNotices();
    }

    private async Task ResetSearch()
    {
        searchText = "";
        await LoadData();
    }

    private void OpenAddModal()
    {
        isNew = true;
        editingNotice = new MasterNoticeDto
        {
            notice_id = 0,
            show_order = 1,
            notice_type = 1,
            start_date = DateTime.Now,
            end_date = DateTime.Now.AddDays(7),
            insert_date = DateTime.Now,
            update_date = DateTime.Now
        };
        showModal = true;
    }

    private void OpenEditModal(MasterNoticeDto item)
    {
        isNew = false;
        editingNotice = new MasterNoticeDto
        {
            notice_id = item.notice_id,
            notice_title = item.notice_title,
            notice_content = item.notice_content,
            notice_banner_image = item.notice_banner_image,
            notice_link = item.notice_link,
            notice_type = item.notice_type,
            show_order = item.show_order,
            start_date = item.start_date,
            end_date = item.end_date,
            insert_date = item.insert_date,
            update_date = item.update_date
        };
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        editingNotice = null;
    }

    private async Task SaveNotice()
    {
        try
        {
            (bool success, string message) result;

            if (isNew)
            {
                result = await _gameClient.addNoticeAsync(editingNotice);
            }
            else
            {
                result = await _gameClient.editNoticeAsync(editingNotice);
            }

            if (result.success)
            {
                await JS.InvokeVoidAsync("alert", result.message);
                CloseModal();
                await LoadData();
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"저장 실패: {result.message}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"오류 발생: {ex.Message}");
        }
    }
}