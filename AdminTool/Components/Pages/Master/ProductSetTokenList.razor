@page "/master/product_set_tokens"

@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using AdminTool.API
@using SharedData.Dto.Admin

@inject GameServerClient _gameClient
@inject IJSRuntime JS

<style>
    .table-scroll-container {
        height: calc(100vh - 250px);
        overflow-y: auto;
        border: 1px solid #dee2e6;
    }
    .table-scroll-container thead th {
        position: sticky; top: 0; z-index: 1;
    }
    .fab-btn {
        position: fixed; bottom: 30px; right: 30px;
        width: 60px; height: 60px; border-radius: 50%;
        font-size: 30px; box-shadow: 0 4px 8px rgba(0,0,0,0.3);
        z-index: 1000; display: flex; align-items: center; justify-content: center; padding-bottom: 5px;
    }
    .img-preview {
        max-width: 50px; max-height: 50px; object-fit: contain; border: 1px solid #ddd; border-radius: 4px; background-color: #f8f9fa;
    }
</style>

<h3>토큰 교환소(Product Set Token) 관리</h3>

<div class="row mb-3">
    <div class="col-md-6">
        <div class="input-group">
            <input type="text" class="form-control" placeholder="ID 또는 상품명 검색"
                   @bind="searchText" @bind:event="oninput" @onkeyup="HandleKeyUp" />
            <button class="btn btn-primary" @onclick="SearchTokens">검색</button>
            <button class="btn btn-secondary" @onclick="ResetSearch">초기화</button>
        </div>
    </div>
</div>

@if (tokenList == null)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="table-scroll-container bg-white">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark sticky-top">
                <tr>
                    <th style="width: 80px;">ID</th>
                    <th style="width: 60px;">순서</th>
                    <th>토큰 그룹</th>
                    <th>이미지</th>
                    <th>상품명</th>
                    <th>가격 (Token)</th>
                    <th>구매 제한</th>
                    <th>지급 보상 (Reward IDs)</th>
                    <th>기간</th>
                    <th style="width: 80px;">관리</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in tokenList)
                {
                    <tr>
                        <td>@item.product_set_token_id</td>
                        <td>@item.show_order</td>
                        <td>
                            @if (item.token_reward_group.HasValue && item.token_reward_group > 0)
                            {
                                <span class="badge bg-secondary">Grp: @item.token_reward_group</span>
                            }
                            else
                            {
                                <span class="text-muted small">-</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.image))
                            {
                                <img src="@item.image" class="img-preview" onerror="this.style.display='none'" />
                            }
                            else
                            {
                                <span class="text-muted small">-</span>
                            }
                        </td>
                        <td class="fw-bold">@item.product_name</td>
                        <td>
                            <span class="badge bg-warning text-dark fs-6">🪙 @item.price_token.ToString("N0")</span>
                        </td>
                        <td>
                            @if (item.buy_upper_limit > 0)
                            {
                                <span class="badge bg-danger">@item.buy_upper_limit 회</span>
                            }
                            else
                            {
                                <span class="badge bg-success">무제한</span>
                            }
                        </td>
                        <td>
                            <small>
                                1. ID: @item.reward_id_1 <br/>
                                @if (item.reward_id_2.HasValue && item.reward_id_2 > 0)
                                {
                                    <span>2. ID: @item.reward_id_2</span> <br/>
                                }
                                @if (item.reward_id_3.HasValue && item.reward_id_3 > 0)
                                {
                                    <span>3. ID: @item.reward_id_3</span>
                                }
                            </small>
                        </td>
                        <td>
                            <small>
                                @item.start_date.ToString("yy-MM-dd") <br />
                                @(item.end_date.HasValue ? item.end_date.Value.ToString("yy-MM-dd") : "무기한")
                            </small>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-info text-white" @onclick="() => OpenEditModal(item)">
                                상세
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<button class="btn btn-primary fab-btn" @onclick="OpenAddModal" title="신규 토큰 상품 추가"> + </button>

@if (showModal && editingToken != null)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @(isNew ? "신규 토큰 상품 등록" : $"토큰 상품 수정 ({editingToken.product_set_token_id})")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    
                    <h6 class="border-bottom pb-2 mb-3 text-primary">기본 상품 정보</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-3">
                            <label class="form-label fw-bold">ID (PK)</label>
                            <input type="number" class="form-control" @bind="editingToken.product_set_token_id" disabled="@(!isNew)" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">표시 순서</label>
                            <input type="number" class="form-control" @bind="editingToken.show_order" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">토큰 그룹 (Group ID)</label>
                            <input type="number" class="form-control" @bind="editingToken.token_reward_group" />
                            <div class="form-text">특정 조건/분류 시 사용</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">상품명 (Product Name)</label>
                            <input type="text" class="form-control" @bind="editingToken.product_name" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">상품 상세 설명</label>
                            <textarea class="form-control" rows="2" @bind="editingToken.product_detail"></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label">아이콘/배너 이미지 경로</label>
                            <input type="text" class="form-control" @bind="editingToken.image" />
                        </div>
                    </div>

                    <h6 class="border-bottom pb-2 mb-3 text-primary">가격 및 구매 제한</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-warning">판매 가격 (Token)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-warning text-dark">🪙</span>
                                <input type="number" class="form-control" @bind="editingToken.price_token" />
                            </div>
                            <div class="form-text">소모할 토큰 수량</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">구매 제한 횟수</label>
                            <input type="number" class="form-control" @bind="editingToken.buy_upper_limit" />
                            <div class="form-text">0이면 무제한</div>
                        </div>
                    </div>

                    <h6 class="border-bottom pb-2 mb-3 text-primary">지급 보상 (Reward IDs)</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">보상 1 (필수)</label>
                            <input type="number" class="form-control" @bind="editingToken.reward_id_1" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">보상 2 (선택)</label>
                            <input type="number" class="form-control" @bind="editingToken.reward_id_2" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">보상 3 (선택)</label>
                            <input type="number" class="form-control" @bind="editingToken.reward_id_3" />
                        </div>
                        <div class="col-12 form-text">
                            MasterReward 테이블의 ID를 입력하세요. (없으면 0 또는 비움)
                        </div>
                    </div>

                    <h6 class="border-bottom pb-2 mb-3 text-primary">판매 기간</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">시작일</label>
                            <input type="datetime-local" class="form-control" @bind="editingToken.start_date" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">종료일</label>
                            <input type="datetime-local" class="form-control" @bind="editingToken.end_date" />
                            <div class="form-text">비워두면 무기한 판매</div>
                        </div>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">취소</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveToken">
                        @(isNew ? "신규 등록" : "수정 저장")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<MasterProductSetTokenDto> tokenList;
    private string searchText = "";

    private bool showModal = false;
    private bool isNew = false;
    private MasterProductSetTokenDto editingToken;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        tokenList = await _gameClient.getProductSetTokens();
        if (!string.IsNullOrEmpty(searchText))
        {
            await SearchTokens();
        }
    }

    private async Task SearchTokens()
    {
        if (tokenList == null || tokenList.Count == 0) await LoadData();

        var query = tokenList.AsQueryable();

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            if (int.TryParse(searchText, out int searchId))
            {
                query = query.Where(p => p.product_set_token_id == searchId);
            }
            else
            {
                query = query.Where(p => p.product_name.Contains(searchText));
            }
        }

        tokenList = query.OrderBy(p => p.product_set_token_id).ThenBy(p => p.show_order).ToList();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchTokens();
    }

    private async Task ResetSearch()
    {
        searchText = "";
        await LoadData();
    }

    private void OpenAddModal()
    {
        isNew = true;
        editingToken = new MasterProductSetTokenDto
        {
            product_set_token_id = 0,
            token_reward_group = null,
            show_order = 1,
            buy_upper_limit = 0,
            price_token = 0,
            reward_id_1 = 0,
            start_date = DateTime.Now,
            end_date = null,
            insert_date = DateTime.Now,
            update_date = DateTime.Now
        };
        showModal = true;
    }

    private void OpenEditModal(MasterProductSetTokenDto item)
    {
        isNew = false;
        editingToken = new MasterProductSetTokenDto
        {
            product_set_token_id = item.product_set_token_id,
            token_reward_group = item.token_reward_group,
            show_order = item.show_order,
            buy_upper_limit = item.buy_upper_limit,
            price_token = item.price_token,
            product_name = item.product_name,
            product_detail = item.product_detail,
            image = item.image,
            reward_id_1 = item.reward_id_1,
            reward_id_2 = item.reward_id_2,
            reward_id_3 = item.reward_id_3,
            start_date = item.start_date,
            end_date = item.end_date,
            insert_date = item.insert_date,
            update_date = item.update_date
        };
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        editingToken = null;
    }

    private async Task SaveToken()
    {
        try
        {
            (bool success, string message) result;

            if (isNew)
            {
                result = await _gameClient.addProductSetTokenAsync(editingToken);
            }
            else
            {
                result = await _gameClient.editProductSetTokenAsync(editingToken);
            }

            if (result.success)
            {
                await JS.InvokeVoidAsync("alert", result.message);
                CloseModal();
                await LoadData();
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"저장 실패: {result.message}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"오류 발생: {ex.Message}");
        }
    }
}