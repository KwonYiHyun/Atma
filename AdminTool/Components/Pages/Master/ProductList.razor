@page "/master/products"

@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using AdminTool.API
@using SharedData.Dto.Admin

@inject GameServerClient _gameClient
@inject IJSRuntime JS

<style>
    .table-scroll-container {
        height: calc(100vh - 250px);
        overflow-y: auto;
        border: 1px solid #dee2e6;
    }

        .table-scroll-container thead th {
            position: sticky;
            top: 0;
            z-index: 1;
        }

    .fab-btn {
        position: fixed;
        bottom: 30px;
        right: 30px;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        font-size: 30px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.3);
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding-bottom: 5px;
    }
</style>

<h3>상점 상품(Product) 관리</h3>

<div class="row mb-3">
    <div class="col-md-6">
        <div class="input-group">
            <input type="text" class="form-control" placeholder="ID 또는 상품명 검색"
                   @bind="searchText" @bind:event="oninput" @onkeyup="HandleKeyUp" />
            <button class="btn btn-primary" @onclick="SearchProducts">검색</button>
            <button class="btn btn-secondary" @onclick="ResetSearch">초기화</button>
        </div>
    </div>
</div>

@if (productList == null)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="table-scroll-container bg-white">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark sticky-top">
                <tr>
                    <th style="width: 80px;">ID</th>
                    <th>상품명</th>
                    <th>타입</th>
                    <th>가격 (Price)</th>
                    <th>지급 재화 (Prism)</th>
                    <th>상세 설명</th>
                    <th>기간</th>
                    <th style="width: 100px;">관리</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in productList)
                {
                    <tr>
                        <td>@product.product_id</td>
                        <td class="fw-bold">@product.product_name</td>
                        <td>
                            @switch (product.product_type)
                            {
                                case 1:
                                    <span class="badge bg-primary">일반</span>
                                    break;
                                case 2:
                                    <span class="badge bg-success">특별</span>
                                    break;
                                default:
                                    <span class="badge bg-secondary">기타(@product.product_type)</span>
                                    break;
                            }
                        </td>
                        <td>
                            @product.price.ToString("N0")
                        </td>
                        <td>
                            <span class="text-primary fw-bold">@product.prism.ToString("N0")</span>
                        </td>
                        <td>
                            <div class="text-truncate" style="max-width: 200px;">
                                @product.product_detail
                            </div>
                        </td>
                        <td>
                            <small>
                                @product.start_date.ToString("yy-MM-dd") <br />
                                @(product.end_date.HasValue? product.end_date.Value.ToString("yy-MM-dd") : "무기한")
                            </small>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-info text-white" @onclick="() => OpenEditModal(product)">
                                상세
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<button class="btn btn-primary fab-btn" @onclick="OpenAddModal" title="신규 상품 추가"> + </button>

@if (showModal && editingProduct != null)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @(isNew ? "신규 상품 등록" : $"상품 수정 ({editingProduct.product_id})")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">

                    <h6 class="border-bottom pb-2 mb-3 text-primary">상품 기본 정보</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-3">
                            <label class="form-label fw-bold">ID (PK)</label>
                            <input type="number" class="form-control" @bind="editingProduct.product_id" disabled="@(!isNew)" />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label fw-bold">상품명</label>
                            <input type="text" class="form-control" @bind="editingProduct.product_name" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">상품 타입</label>
                            <select class="form-select" @bind="editingProduct.product_type">
                                <option value="1">단품 (Gem)</option>
                                <option value="2">패키지 (Package)</option>
                                <option value="3">월정액 (Monthly)</option>
                                <option value="99">기타 (Etc)</option>
                            </select>
                        </div>
                    </div>

                    <h6 class="border-bottom pb-2 mb-3 text-primary">가격 및 구성</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">판매 가격 (Price)</label>
                            <div class="input-group">
                                <span class="input-group-text">₩</span> <input type="number" class="form-control" @bind="editingProduct.price" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">지급 재화량 (Prism)</label>
                            <input type="number" class="form-control" @bind="editingProduct.prism" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">상품 상세 설명 (Detail)</label>
                            <textarea class="form-control" rows="3" @bind="editingProduct.product_detail" placeholder="예: [보너스] 골드 10000 지급"></textarea>
                        </div>
                    </div>

                    <h6 class="border-bottom pb-2 mb-3 text-primary">판매 기간</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">판매 시작일</label>
                            <input type="datetime-local" class="form-control" @bind="editingProduct.start_date" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">판매 종료일</label>
                            <input type="datetime-local" class="form-control" @bind="editingProduct.end_date" />
                            <div class="form-text">비워두면 무기한 판매</div>
                        </div>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">취소</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveProduct">
                        @(isNew ? "신규 등록" : "수정 저장")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<MasterProductDto> productList;
    private string searchText = "";

    private bool showModal = false;
    private bool isNew = false;
    private MasterProductDto editingProduct;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        productList = await _gameClient.getProducts();
        if (!string.IsNullOrEmpty(searchText))
        {
            await SearchProducts();
        }
    }

    private async Task SearchProducts()
    {
        if (productList == null || productList.Count == 0) await LoadData();

        var query = productList.AsQueryable();

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            if (int.TryParse(searchText, out int searchId))
            {
                query = query.Where(p => p.product_id == searchId);
            }
            else
            {
                query = query.Where(p => p.product_name.Contains(searchText));
            }
        }

        productList = query.OrderBy(p => p.product_id).ToList();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchProducts();
    }

    private async Task ResetSearch()
    {
        searchText = "";
        await LoadData();
    }

    private void OpenAddModal()
    {
        isNew = true;
        editingProduct = new MasterProductDto
        {
            product_id = 0,
            product_type = 1,
            price = 0,
            prism = 0,
            start_date = DateTime.Now,
            end_date = null,
            insert_date = DateTime.Now,
            update_date = DateTime.Now
        };
        showModal = true;
    }

    private void OpenEditModal(MasterProductDto item)
    {
        isNew = false;
        editingProduct = new MasterProductDto
        {
            product_id = item.product_id,
            product_name = item.product_name,
            prism = item.prism,
            price = item.price,
            product_type = item.product_type,
            product_detail = item.product_detail,
            start_date = item.start_date,
            end_date = item.end_date,
            insert_date = item.insert_date,
            update_date = item.update_date
        };
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        editingProduct = null;
    }

    private async Task SaveProduct()
    {
        try
        {
            (bool success, string message) result;

            if (isNew)
            {
                result = await _gameClient.addProductAsync(editingProduct);
            }
            else
            {
                result = await _gameClient.editProductAsync(editingProduct);
            }

            if (result.success)
            {
                await JS.InvokeVoidAsync("alert", result.message);
                CloseModal();
                await LoadData();
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"저장 실패: {result.message}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"오류 발생: {ex.Message}");
        }
    }
}