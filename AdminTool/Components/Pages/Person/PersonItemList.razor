@page "/person/item"

@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using AdminTool.API
@using SharedData.Dto.Admin

@inject GameServerClient _gameClient
@inject IJSRuntime JS

<style>
    .table-scroll-container {
        height: calc(100vh - 200px);
        overflow-y: auto;
        border: 1px solid #dee2e6;
    }

        .table-scroll-container thead th {
            position: sticky;
            top: 0;
            z-index: 1;
        }
</style>

<h3>유저 인벤토리(Item) 관리</h3>

<div class="row mb-3">
    <div class="col-md-6">
        <div class="input-group">
            <span class="input-group-text bg-light fw-bold">Person ID</span>
            <input type="number" class="form-control" placeholder="조회할 유저 ID 입력"
                   @bind="searchPersonId" @bind:event="oninput" @onkeyup="HandleKeyUp" />
            <button class="btn btn-primary" @onclick="SearchItems">인벤토리 조회</button>
        </div>
    </div>
</div>

@if (itemList == null)
{
    <div class="alert alert-info">유저 ID를 입력하고 조회 버튼을 눌러주세요.</div>
}
else if (itemList.Count == 0)
{
    <div class="alert alert-warning">보유한 아이템이 없거나 유저를 찾을 수 없습니다.</div>
}
else
{
    <div class="table-scroll-container bg-white">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark sticky-top">
                <tr>
                    <th style="width: 80px;">PK ID</th>
                    <th>Item ID</th>
                    <th>보유 수량 (Amount)</th>
                    <th>최근 획득/수정일</th>
                    <th style="width: 140px;">관리</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in itemList)
                {
                    <tr>
                        <td>@item.person_item_id</td>
                        <td class="fw-bold text-primary">Item ID: @item.item_id</td>
                        <td><span class="badge bg-success fs-6">@item.amount.ToString("N0") 개</span></td>
                        <td>@item.update_date.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>
                            <button class="btn btn-sm btn-info text-white" @onclick="() => OpenEditModal(item)">수정</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDelete(item.person_item_id, item.item_id)">회수</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (showModal && editingItem != null)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">아이템 수량 수정 (Item: @editingItem.item_id)</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">보유 수량 (Amount)</label>
                        <input type="number" class="form-control" @bind="editingItem.amount" />
                        <div class="form-text text-danger">※ 유저의 실제 인벤토리 수량이 강제로 변경됩니다.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">취소</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveItem">저장</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private int? searchPersonId;
    private List<PersonItemDto>? itemList;
    private bool showModal = false;
    private PersonItemDto? editingItem;

    private async Task SearchItems()
    {
        if (searchPersonId == null || searchPersonId <= 0)
        {
            await JS.InvokeVoidAsync("alert", "유효한 ID를 입력하세요.");
            return;
        }
        itemList = await _gameClient.getPersonItemsAsync(searchPersonId.Value);
        if (itemList != null)
        {
            itemList = itemList.OrderByDescending(i => i.update_date).ToList();
        }
    }
    private async Task HandleKeyUp(KeyboardEventArgs e) { 
        if (e.Key == "Enter")
        {
            await SearchItems();
        }
    }

    private void OpenEditModal(PersonItemDto item)
    {
        editingItem = new PersonItemDto { person_item_id = item.person_item_id, person_id = item.person_id, item_id = item.item_id, amount = item.amount };
        showModal = true;
    }
    private void CloseModal() { showModal = false; editingItem = null; }

    private async Task SaveItem()
    {
        if (editingItem == null)
        {
            return;
        }
        var result = await _gameClient.editPersonItemAsync(editingItem);
        if (result.Item1)
        {
            await JS.InvokeVoidAsync("alert", "수정되었습니다.");
            CloseModal();
            await SearchItems();
        }
        else
        {
            await JS.InvokeVoidAsync("alert", $"실패: {result.Item2}");
        }
    }

    private async Task ConfirmDelete(int personId, int itemId)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"정말 Item {itemId} 데이터를 인벤토리에서 완전히 회수(삭제)하시겠습니까?"))
        {
            var result = await _gameClient.deletePersonItemAsync(personId);
            if (result.Item1) {
                await JS.InvokeVoidAsync("alert", "회수 완료.");
                await SearchItems();

                // var cacheResult = await _gameClient.deletePersonItemCacheAsync(personId);
                // if (cacheResult)
                // {
                //     //await JS.InvokeVoidAsync("alert", "캐시초기화 성공.");
                // }
                // else
                // {
                //     await JS.InvokeVoidAsync("alert", "캐시초기화 실패.");
                // }
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"회수 실패: {result.Item2}");
            }
        }
    }
}