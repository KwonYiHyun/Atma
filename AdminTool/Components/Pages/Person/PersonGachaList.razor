@page "/person/gacha"

@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using AdminTool.API
@using SharedData.Dto.Admin

@inject GameServerClient _gameClient
@inject IJSRuntime JS

<style>
    .table-scroll-container {
        height: calc(100vh - 200px);
        overflow-y: auto;
        border: 1px solid #dee2e6;
    }

        .table-scroll-container thead th {
            position: sticky;
            top: 0;
            z-index: 1;
        }
</style>

<h3>유저 가챠 횟수(Gacha Record) 관리</h3>

<div class="row mb-3">
    <div class="col-md-6">
        <div class="input-group">
            <span class="input-group-text bg-light fw-bold">Person ID</span>
            <input type="number" class="form-control" placeholder="조회할 유저 ID 입력"
                   @bind="searchPersonId" @bind:event="oninput" @onkeyup="HandleKeyUp" />
            <button class="btn btn-primary" @onclick="SearchGachas">기록 조회</button>
        </div>
    </div>
</div>

@if (gachaList == null)
{
    <div class="alert alert-info">유저 ID를 입력하고 조회 버튼을 눌러주세요.</div>
}
else if (gachaList.Count == 0)
{
    <div class="alert alert-warning">해당 유저의 가챠 이용 기록이 없습니다.</div>
}
else
{
    <div class="table-scroll-container bg-white">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark sticky-top">
                <tr>
                    <th style="width: 80px;">PK ID</th>
                    <th>가챠 배너 ID (Gacha ID)</th>
                    <th>진행 횟수 (Count)</th>
                    <th>마지막 진행일</th>
                    <th style="width: 140px;">관리</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var g in gachaList)
                {
                    <tr>
                        <td>@g.person_gacha_id</td>
                        <td class="fw-bold text-primary">Gacha ID: @g.gacha_id</td>
                        <td><span class="badge bg-warning text-dark fs-6">@g.gacha_count 회</span></td>
                        <td>@g.update_date.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>
                            <button class="btn btn-sm btn-info text-white" @onclick="() => OpenEditModal(g)">조정</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDelete(g.person_gacha_id, g.gacha_id)">기록 삭제</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (showModal && editingGacha != null)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">가챠 횟수 조정 (Gacha: @editingGacha.gacha_id)</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">진행 횟수 (Count)</label>
                        <input type="number" class="form-control" @bind="editingGacha.gacha_count" />
                        <div class="form-text text-danger">※ 천장/마일리지 시스템에 직접적인 영향을 줍니다.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">취소</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveGacha">저장</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private int? searchPersonId;
    private List<PersonGachaDto>? gachaList;
    private bool showModal = false;
    private PersonGachaDto? editingGacha;

    private async Task SearchGachas()
    {
        if (searchPersonId == null || searchPersonId <= 0) { await JS.InvokeVoidAsync("alert", "유효한 ID를 입력하세요."); return; }
        gachaList = await _gameClient.getPersonGachasAsync(searchPersonId.Value);
        if (gachaList != null) gachaList = gachaList.OrderByDescending(g => g.update_date).ToList();
    }
    private async Task HandleKeyUp(KeyboardEventArgs e) { if (e.Key == "Enter") await SearchGachas(); }

    private void OpenEditModal(PersonGachaDto item)
    {
        editingGacha = new PersonGachaDto { person_gacha_id = item.person_gacha_id, gacha_id = item.gacha_id, gacha_count = item.gacha_count };
        showModal = true;
    }
    private void CloseModal() { showModal = false; editingGacha = null; }

    private async Task SaveGacha()
    {
        if (editingGacha == null) return;
        var result = await _gameClient.editPersonGachaAsync(editingGacha);
        if (result.Item1) { await JS.InvokeVoidAsync("alert", "조정되었습니다."); CloseModal(); await SearchGachas(); }
        else await JS.InvokeVoidAsync("alert", $"실패: {result.Item2}");
    }

    private async Task ConfirmDelete(int pkId, int gachaId)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Gacha ID {gachaId}의 진행 기록을 완전히 삭제하시겠습니까?"))
        {
            var result = await _gameClient.deletePersonGachaAsync(pkId);
            if (result.Item1) { await JS.InvokeVoidAsync("alert", "삭제 완료."); await SearchGachas(); }
            else await JS.InvokeVoidAsync("alert", $"삭제 실패: {result.Item2}");
        }
    }
}