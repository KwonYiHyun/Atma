@implements IDisposable
@inject NavigationManager NavigationManager

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">운영툴</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="oi oi-home" aria-hidden="true"></span> 대시보드
            </NavLink>
        </div>

        <div class="nav-item px-3 mt-3 pt-2 border-top border-secondary">
            <span class="text-uppercase text-white-50 small fw-bold px-3">Categories</span>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="master">
                <span class="oi oi-layers" aria-hidden="true"></span> 마스터 관리
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="person">
                <span class="oi oi-people" aria-hidden="true"></span> 사용자 관리
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="admin">
                <span class="oi oi-wrench" aria-hidden="true"></span> 운영자 기능
            </NavLink>
        </div>

        <div class="nav-item px-3 mt-3 pt-2 border-top border-secondary"></div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="info">
                <span class="oi oi-info" aria-hidden="true"></span> Info
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}